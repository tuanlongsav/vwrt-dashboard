#!/usr/bin/lua
-- AdBlock Fast Delete List API
-- Params: name (string)

-- Dynamic Path Resolution
local source = debug.getinfo(1).source
local script_path = source:match("@?(.*[\\/])")
if script_path then
    local cgi_root = script_path:match("(.*cgi%-bin/)")
    if cgi_root then
        package.path = cgi_root .. "?.lua;" .. package.path
    end
end
if not package.path:find("/www/vwrt/cgi-bin") then
    package.path = "/www/vwrt/cgi-bin/?.lua;" .. package.path
end

local json = require("luci.jsonc")
local uci = require("luci.model.uci").cursor()
local csrf = require("lib.csrf")

print("Content-Type: application/json; charset=utf-8")
print("")

local function parse_post_data()
    local content_length = tonumber(os.getenv("CONTENT_LENGTH") or 0)
    if content_length > 0 then
        local raw = io.read(content_length)
        return json.parse(raw) or {}
    end
    return {}
end

-- Parse POST data once
local input_data = parse_post_data()

-- CSRF Check
local token = csrf.get_token_from_request() or csrf.get_token_from_body(input_data)
if not csrf.validate_token(token) then
    print(json.stringify({ success = false, error = "CSRF Token không hợp lệ!" }))
    os.exit()
end

local function delete_list()
    local data = input_data
    
    if not data.url or data.url == "" then
        print(json.stringify({ success = false, error = "URL danh sách không hợp lệ." }))
        return
    end
    
    -- Find and delete the list by URL
    local deleted = false
    local sections_to_delete = {}
    
    uci:foreach("adblock-fast", "file_url", function(s)
        if s.url == data.url then
            table.insert(sections_to_delete, s[".name"])
        end
    end)
    
    if #sections_to_delete == 0 then
        print(json.stringify({ success = false, error = "Không tìm thấy danh sách với tên này." }))
        return
    end
    
    for _, section_name in ipairs(sections_to_delete) do
        uci:delete("adblock-fast", section_name)
        deleted = true
    end
    
    if deleted then
        uci:commit("adblock-fast")
        print(json.stringify({ success = true, message = "Đã xóa danh sách." }))
    else
        print(json.stringify({ success = false, error = "Không thể xóa danh sách." }))
    end
end

local ok, err = pcall(delete_list)
if not ok then
    print(json.stringify({ success = false, error = tostring(err) }))
end

