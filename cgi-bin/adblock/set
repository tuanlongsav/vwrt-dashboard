#!/usr/bin/lua
-- AdBlock Fast Set API
-- Rewrite to fix syntax/logic errors and add debug logging

-- Dynamic Path Resolution
local source = debug.getinfo(1).source
local script_path = source:match("@?(.*[\\/])")
if script_path then
    local cgi_root = script_path:match("(.*cgi%-bin/)")
    if cgi_root then
        package.path = cgi_root .. "?.lua;" .. package.path
    end
end
if not package.path:find("/www/vwrt/cgi-bin") then
    package.path = "/www/vwrt/cgi-bin/?.lua;" .. package.path
end

local json = require("luci.jsonc")
local uci = require("luci.model.uci").cursor()
local csrf = require("lib.csrf")

print("Content-Type: application/json; charset=utf-8")
print("")

local function log(msg)
    local f = io.open("/tmp/adblock_set.log", "a")
    if f then
        f:write(os.date() .. " " .. tostring(msg) .. "\n")
        f:close()
    end
end
log("--- Script Start ---")

local function get_input()
    local len = tonumber(os.getenv("CONTENT_LENGTH") or 0)
    if len > 0 then
        local raw = io.read(len)
        return json.parse(raw) or {}
    end
    return {}
end

-- 1. Read Input once
local input_data = get_input()

-- 2. Validate CSRF
local header_token = csrf.get_token_from_request()
local body_token = csrf.get_token_from_body(input_data)
local token = header_token or body_token

if not csrf.validate_token(token) then
    -- Debug Message
    local debug_msg = string.format("Invalid Token. Header: [%s], Body: [%s], Expected: [See Server]", 
        tostring(header_token), tostring(body_token))
    
    print(json.stringify({ success = false, error = "Lỗi CSRF! " .. debug_msg }))
    os.exit()
end

-- 3. Main Logic
local function set_config()
    local data = input_data
    
    -- Set global enabled status
    if data.enabled ~= nil then
        local val = data.enabled and "1" or "0"
        uci:set("adblock-fast", "config", "enabled", val)
    end
    
    -- Update list enabled status
    if data.lists and type(data.lists) == "table" then
        local enabled_set = {}
        for _, url in ipairs(data.lists) do
            enabled_set[url] = true
        end
        
        uci:foreach("adblock-fast", "file_url", function(s)
            local url = s.url or ""
            local should_enable = enabled_set[url] and "1" or "0"
            uci:set("adblock-fast", s[".name"], "enabled", should_enable)
        end)
    end
    
    -- Commit changes
    uci:commit("adblock-fast")
    
    -- Reload service
    os.execute("/etc/init.d/adblock-fast reload >/dev/null 2>&1 &")
    
    print(json.stringify({ success = true, message = "Đã lưu cấu hình thành công." }))
end

log("Calling pcall set_config")
local ok, err = pcall(set_config)
log("Pcall result: " .. tostring(ok) .. ", Err: " .. tostring(err))

if not ok then
    local err_msg = tostring(err)
    if err_msg == "nil" then err_msg = "Lỗi không xác định (Unknown Error)" end
    print(json.stringify({ success = false, error = err_msg }))
end

