#!/usr/bin/lua
print("Content-type: application/json\n")

local script_path = "/www/vwrt/cgi-bin/"
package.path = script_path .. "?.lua;/www/vwrt/?.lua;" .. package.path

local json = require "luci.jsonc"
local constants = require "lib.constants"
local sms_util = require "lib.sms_util"

function get_query_param(key)
    local query = os.getenv("QUERY_STRING") or ""
    for k, v in string.gmatch(query, "([^&=]+)=([^&=]*)") do
        if k == key then 
            return v:gsub("%%(%x%x)", function(h) return string.char(tonumber(h, 16)) end)
        end
    end
    return nil
end

-- Helper: Read file
local function read_file(path)
    local f = io.open(path, "r")
    if not f then return nil end
    local content = f:read("*all")
    f:close()
    return content
end

-- Get driver for fallback
local function get_driver()
    local handle = io.popen("uci show network | grep '.proto=.atc.'")
    if handle then
        local content = handle:read("*all")
        handle:close()
        if content and content ~= "" then
             return require "drivers.fm350"
        end
    end
    return require "drivers.mmcli"
end

local function get_config()
    return { driver = "dynamic", modem_index = "0" }
end

-- Read from Router Archive (Priority)
local function get_messages_from_archive()
    local ARCHIVE_FILE = constants.PATHS.SMS_ARCHIVE
    local content = read_file(ARCHIVE_FILE)
    
    if not content or content == "" then
        return nil, 0, 0
    end
    
    local ok, archive = pcall(json.parse, content)
    if not ok or not archive or not archive.conversations then
        return nil, 0, 0
    end
    
    -- Flatten conversations into flat message list (for compatibility)
    local messages = {}
    local msg_count = 0
    
    for phone, conv in pairs(archive.conversations) do
        if conv.messages then
            for _, msg in ipairs(conv.messages) do
                msg_count = msg_count + 1
                table.insert(messages, {
                    index = msg.id or "archived_" .. msg_count,
                    number = phone,
                    time = msg.timestamp or "",
                    text = msg.content or "",
                    type = msg.direction or "received",
                    status = msg.direction == "sent" and "sent" or "received"
                })
            end
        end
    end
    
    -- Sort by time (newest first)
    table.sort(messages, function(a, b)
        return (a.time or "") > (b.time or "")
    end)
    
    return messages, msg_count, 50
end

-- Main logic
local force_sync = get_query_param("sync")

-- Signal activity and trigger for reactive sync
pcall(function()
    local f_act = io.open("/tmp/sms_web_activity", "w")
    if f_act then f_act:write(tostring(os.time())); f_act:close() end
    
    local f_trig = io.open("/tmp/sms_sync_trigger", "w")
    if f_trig then f_trig:write("1"); f_trig:close() end
end)

local sms_storage = require "lib.sms_storage"

if force_sync == "true" then
    -- Force read from modem (Refresh button)
    -- Load synced_ids for filtering
    local ARCHIVE_FILE = constants.PATHS.SMS_ARCHIVE
    local archive_content = read_file(ARCHIVE_FILE)
    local synced_ids = {}
    if archive_content and archive_content ~= "" then
        local ok_a, archive_obj = pcall(json.parse, archive_content)
        if ok_a and archive_obj and archive_obj.synced_ids then synced_ids = archive_obj.synced_ids end
    end

    local config = get_config()
    local driver_lib = get_driver()
    local result = driver_lib.get_sms(config)

    local filtered = {}
    if result and result.messages then
        for _, msg in ipairs(result.messages) do
            local fingerprint = sms_util.get_fingerprint(msg)
            if not synced_ids[fingerprint] then
                table.insert(filtered, msg)
            end
        end
    end

    print(json.stringify({
        status = "success",
        data = filtered,
        storage = result and result.storage or { used = 0, total = 0 },
        source = "modem_filtered"
    }))
else
    -- Priority: Read from Router Archive
    local archive = sms_storage.load()
    local archive_messages, used, total = get_messages_from_archive()
    
    if archive_messages then
        print(json.stringify({ 
            status = "success", 
            data = archive_messages,
            storage = { used = used, total = total },
            source = "router"
        }))
    else
        -- Fallback: Read from Modem if archive is incomplete or empty
        -- But FILTER OUT anything in synced_ids to prevent re-appearance of deleted/stuck msgs
        local config = get_config()
        local driver_lib = get_driver()
        local result = driver_lib.get_sms(config)
        
        local synced_ids = archive.synced_ids or {}

        local filtered = {}
        if result.messages then
            for _, msg in ipairs(result.messages) do
                local fingerprint = sms_util.get_fingerprint(msg)
                
                if not synced_ids[fingerprint] then
                    table.insert(filtered, msg)
                end
            end
        end

        print(json.stringify({ 
            status = "success", 
            data = filtered,
            storage = result.storage,
            source = "modem_filtered"
        }))
    end
end