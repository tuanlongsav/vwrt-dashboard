#!/usr/bin/lua

-- Prevent 500 Internal Server Errors by capturing Lua crashes
local function main()
    local cjson = require "cjson"

    -- Dynamic Path Resolution
    local source = debug.getinfo(1).source
    local script_path = source:match("@?(.*[\\/])")
    if script_path then
        local cgi_root = script_path:match("(.*cgi%-bin/)")
        if cgi_root then
            package.path = cgi_root .. "?.lua;" .. package.path
        end
    end
    if not package.path:find("/www/vwrt/cgi-bin") then
        package.path = "/www/vwrt/cgi-bin/?.lua;" .. package.path
    end

    print("Content-Type: application/json\n")

    -- Helper to execute command
    local function exec(cmd)
        local f = io.popen(cmd)
        if not f then return nil end
        local s = f:read("*all")
        f:close()
        return s
    end

    -- Helper to read file
    local function read_file(path)
        local f = io.open(path, "r")
        if not f then return nil end
        local s = f:read("*all")
        f:close()
        return s
    end

    -- 1. Get DHCP Lease Time (Dynamic Logic)
    local lease_time_str = "12h" -- Default
    -- Find the DHCP section responsible for 'lan' interface
    local dhcp_sections = exec("uci show dhcp | grep .interface='lan'")
    if dhcp_sections then
        -- Extract section name e.g. dhcp.lan
        local section = dhcp_sections:match("^(dhcp%.%S+)%.interface='lan'") or "dhcp.lan"
        lease_time_str = exec("uci get " .. section .. ".leasetime") or "12h"
    end

    local function parse_lease_time(s)
        if not s then return 12 * 3600 end
        local val = tonumber(s:match("%d+")) or 12
        if s:match("h") then return val * 3600
        elseif s:match("m") then return val * 60
        elseif s:match("d") then return val * 86400
        else return val * 3600 end -- default hours
    end
    local lease_duration = parse_lease_time(lease_time_str)
    local current_time = os.time()

    -- ensure accounting chain exists
    exec("iptables -N VWRT_ACCT 2>/dev/null")
    exec("iptables -C FORWARD -j VWRT_ACCT 2>/dev/null || iptables -I FORWARD -j VWRT_ACCT")

    -- Parse current counters from iptables-save
    -- Format: [packets:bytes] -A VWRT_ACCT -s 1.2.3.4 ...
    local acct_data = {}
    local acct_raw = exec("iptables-save -c | grep VWRT_ACCT")
    if acct_raw then
        for line in acct_raw:gmatch("[^\r\n]+") do
            local pkts, bytes, rule = line:match("%[(%d+):(%d+)%]%s+(.*)")
            if bytes and rule then
                -- Check if upload or download
                local src_ip = rule:match("-s%s+(%d+.%d+.%d+.%d+)")
                local dst_ip = rule:match("-d%s+(%d+.%d+.%d+.%d+)")
                
                if src_ip then
                    if not acct_data[src_ip] then acct_data[src_ip] = {rx=0, tx=0} end
                    acct_data[src_ip].tx = tonumber(bytes)
                elseif dst_ip then
                    if not acct_data[dst_ip] then acct_data[dst_ip] = {rx=0, tx=0} end
                    acct_data[dst_ip].rx = tonumber(bytes)
                end
            end
        end
    end

    -- 2. Read DHCP Leases (for Hostnames & Uptime)
    local leases = {}
    local dcontent = read_file("/tmp/dhcp.leases")
    if dcontent then
        for line in dcontent:gmatch("[^\r\n]+") do
            -- Format: expiry mac ip name clientid
            local ts, mac, ip, name = line:match("(%d+)%s+(%S+)%s+(%S+)%s+(%S+)")
            if mac and ts then
                -- Estimate uptime: Duration - (Expiry - Now)
                local expiry = tonumber(ts)
                local connected = lease_duration - (expiry - current_time)
                if connected < 0 then connected = 0 end
                
                leases[mac:lower()] = {
                    name = (name ~= "*") and name or "Unknown",
                    uptime = connected
                }
            end
        end
    end

    -- 3. Read Bridge FDB to map MAC -> Interface
    local fdb = {}
    local bridge_out = exec("bridge fdb show 2>/dev/null")
    if bridge_out then
        for line in bridge_out:gmatch("[^\r\n]+") do
            -- 40:a5:ef:54:3f:09 dev rax0 offload master br-lan
            local mac, dev = line:match("(%x%x:%x%x:%x%x:%x%x:%x%x:%x%x)%s+dev%s+(%S+)")
            if mac and dev then
                fdb[mac:lower()] = dev
            end
        end
    end

    -- 4. Read iwinfo for Active WiFi clients (The Source of Truth for WiFi)
    local active_wifi = {}
    local wifi_interfaces = {}

    -- Auto-detect wifi interfaces using iwinfo mechanisms
    -- This is robust across different drivers (ath10k, mt76, etc.)
    local ubus_wifi = exec("ubus list | grep hostapd")
    if ubus_wifi then
        for iface in ubus_wifi:gmatch("hostapd%.(%S+)") do
            table.insert(wifi_interfaces, iface)
        end
    end
    -- Fallback: Scan /sys/class/net for wireless interfaces containing 'wlan', 'ra', 'ath'
    if #wifi_interfaces == 0 then
        local sys_net = exec("ls /sys/class/net")
        if sys_net then
            for iface in sys_net:gmatch("%S+") do
                -- Common wireless prefixes
                if iface:match("^ra") or iface:match("^wlan") or iface:match("^ath") or iface:match("^wl") then
                    -- Verify it is actually wireless
                    if exec("iwinfo " .. iface .. " info 2>/dev/null") then
                        table.insert(wifi_interfaces, iface)
                    end
                end
            end
        end
    end

    for _, iface in ipairs(wifi_interfaces) do
        local assoc = exec("iwinfo " .. iface .. " assoclist 2>/dev/null")
        if assoc then
            for raw_mac, sig in assoc:gmatch("(%x%x:%x%x:%x%x:%x%x:%x%x:%x%x)%s+([%-%d]+)%s+dBm") do
                local mac = raw_mac:lower()
                active_wifi[mac] = {
                    iface = iface,
                    signal = tonumber(sig),
                    noise = tonumber(assoc:match(raw_mac:upper() .. ".-/%s+([%-%d]+)%s+dBm")),
                    snr = tonumber(assoc:match(raw_mac:upper() .. ".-SNR%s+([%-%d]+)"))
                }
            end
        end
    end

    -- 5. Construct Client List
    -- We iterate ARP to get IP + MAC, but filter based on FDB/WiFi status
    local clients = {}
    
    -- Load blocked list from UCI
    local uci = require("luci.model.uci").cursor()
    local blocked_list = uci:get("vwrt", "clients", "blocked") or {}
    if type(blocked_list) == "string" then blocked_list = {blocked_list} end
    local is_blocked = {}
    for _, bmac in ipairs(blocked_list) do
        is_blocked[bmac:lower()] = true
    end

    local acontent = read_file("/proc/net/arp")
    if acontent then
        for line in acontent:gmatch("[^\r\n]+") do
            local ip, hw, flags, mac, mask, dev = line:match("(%S+)%s+(%S+)%s+(%S+)%s+(%S+)%s+(%S+)%s+(%S+)")
            -- Filter: Must have MAC, not zero-MAC, and NOT be a stale entry (flags == 0x0)
            if mac and mac:find(":") and mac ~= "00:00:00:00:00:00" and flags ~= "0x0" then
                mac = mac:lower()
                
                -- SKIP if MAC is in blocked list
                local should_include = not is_blocked[mac]
                
                local fdb_iface = fdb[mac] or ""
                local is_wifi_port = fdb_iface:match("^ra") or fdb_iface:match("^wlan") or fdb_iface:match("^ath") or fdb_iface:match("^wl")
                
                if should_include then
                    local c_type = "LAN"
                    local c_sig = nil
                    
                    if active_wifi[mac] then
                        local iface_info = exec("iwinfo " .. active_wifi[mac].iface .. " info 2>/dev/null") or ""
                        local is_5g = iface_info:find("5%.%d+ GHz") or iface_info:find("Channel: %d+ %([3-9]%d") or iface_info:find("Channel: %d+ %(1[0-9]%d")

                        c_type = is_5g and "WiFi 5G" or "WiFi 2.4G"
                        c_sig = active_wifi[mac].signal
                    elseif is_wifi_port then
                        -- MAC seen on a wireless port but not associated → drop (likely stale)
                        should_include = false
                    elseif fdb_iface == "" and dev ~= "br-lan" and dev ~= "br0" then
                        -- Strict filter: Only exclude if NOT on main bridge AND not in FDB
                        -- If on br-lan but not in FDB (e.g. bridge cmd missing), we assume LAN
                        should_include = false
                    end

                    -- Re-check should_include after potential status changes
                    if should_include then
                        local info = leases[mac] or {}
                        
                        -- Traffic Accounting Sync
                        local stats = acct_data[ip]
                        if not stats and ip and ip ~= "" then
                            exec(string.format("iptables -A VWRT_ACCT -s %s -j RETURN", ip))
                            exec(string.format("iptables -A VWRT_ACCT -d %s -j RETURN", ip))
                        end
                        
                        local rx = stats and stats.rx or 0
                        local tx = stats and stats.tx or 0

                        clients[mac] = {
                            ip = ip,
                            mac = mac,
                            name = info.name or "*",
                            interface = fdb_iface ~= "" and fdb_iface or dev,
                            type = c_type,
                            signal = c_sig,
                            connected_time = info.uptime or 0,
                            rx = rx, tx = tx, total = rx + tx
                        }
                    end
                end
            end
        end
    end

    local result = {}
    for _, data in pairs(clients) do
        table.insert(result, data)
    end

    print(cjson.encode({ status = "success", data = result }))
end

-- MAIN ENTRY WITH ERROR HANDLING
local status, err = pcall(main)
if not status then
    -- Fallback header in case main() crashed before printing it
    -- Note: If main crashed AFTER printing header, we might have double headers, 
    -- but better than 500 error. Check if we can detect it? Hard from here.
    -- We'll assume if it crashed, we might need to output json error.
    
    -- If the error isn't a string, make it one
    err = tostring(err or "Unknown Error")
    
    -- Escape quotes
    local safe_err = err:gsub('"', '\\"'):gsub('\n', ' ')
    
    -- Output valid JSON
    -- We probably shouldn't print Content-Type again if it was already printed, 
    -- but we can't be sure. Most browsers tolerate duplicate headers of same type.
    print("Content-Type: application/json\n") 
    print('{ "status": "error", "message": "' .. safe_err .. '" }')
end
