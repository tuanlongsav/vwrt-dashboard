#!/usr/bin/lua
-- Reboot Schedule Get API
-- Returns: { enabled, schedules: [{ id, time, days, active }] }

local json = require("luci.jsonc")
local uci = require("luci.model.uci").cursor()

print("Content-Type: application/json")
print("")

local function read_schedules()
    local schedules = {}
    local schedule_file = "/etc/vwrt_reboot_schedule.json"
    
    local f = io.open(schedule_file, "r")
    if f then
        local content = f:read("*all")
        f:close()
        local data = json.parse(content)
        if data and data.schedules then
            schedules = data.schedules
        end
    end
    
    return schedules
end

local function get_schedule()
    local result = {
        enabled = false,
        schedules = {}
    }
    
    -- Check if scheduling is enabled (via presence of cron entries)
    local p = io.popen("grep -c 'vwrt_reboot' /etc/crontabs/root 2>/dev/null || echo 0")
    if p then
        local count = tonumber(p:read("*l")) or 0
        result.enabled = count > 0
        p:close()
    end
    
    result.schedules = read_schedules()
    
    print(json.stringify(result))
end

local ok, err = pcall(get_schedule)
if not ok then
    print(json.stringify({ error = tostring(err) }))
end
