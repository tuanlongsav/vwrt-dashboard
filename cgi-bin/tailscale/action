#!/usr/bin/lua

local json = require "luci.jsonc"

function read_post_body()
    local len = tonumber(os.getenv("CONTENT_LENGTH") or "0")
    if len == 0 then return nil end
    return io.read(len)
end

function exec(cmd)
    local f = io.popen(cmd)
    if not f then return nil end
    local content = f:read("*all")
    f:close()
    return content
end

function ensure_tailscale_config()
    -- Enable/Restart Network/Firewall is handled at the end
    
    -- 1. Setup Network Interface (Standard Name)
    os.execute("uci set network.tailscale=interface")
    os.execute("uci set network.tailscale.device='tailscale0'")
    
    -- Try to get Tailscale IPs with retries (max 5s)
    local ip4 = nil
    local ip6 = nil
    for i = 1, 5 do
        local handle = io.popen("tailscale ip 2>/dev/null")
        local output = handle:read("*a")
        handle:close()
        
        if output and output ~= "" then
            for line in output:gmatch("[^\r\n]+") do
                if line:match(":") then
                    ip6 = line
                elseif line:match("%d+.%d+.%d+.%d+") then
                    ip4 = line
                end
            end
        end
        
        if ip4 then break end
        os.execute("sleep 1")
    end
    
    if ip4 then
        os.execute("uci set network.tailscale.proto='static'")
        os.execute("uci set network.tailscale.ipaddr='" .. ip4 .. "'")
        os.execute("uci set network.tailscale.netmask='255.255.255.255'")
        if ip6 then
            os.execute("uci set network.tailscale.ip6addr='" .. ip6 .. "/128'")
        end
    else
        -- Pending state
        os.execute("uci set network.tailscale.proto='none'")
    end
    
    os.execute("uci commit network")

    -- 2. Create Firewall Zone and Forwarding
    -- We use standard names now that init script is safe
    os.execute("uci delete firewall.tailscale 2>/dev/null")
    os.execute("uci set firewall.tailscale=zone")
    os.execute("uci set firewall.tailscale.name='tailscale'")
    os.execute("uci set firewall.tailscale.input='ACCEPT'")
    os.execute("uci set firewall.tailscale.forward='ACCEPT'")
    os.execute("uci set firewall.tailscale.output='ACCEPT'")
    os.execute("uci set firewall.tailscale.network='tailscale'")
    os.execute("uci set firewall.tailscale.masq='1'")
    os.execute("uci set firewall.tailscale.mtu_fix='1'")
    
    -- Forwarding Rule: Tailscale -> LAN
    os.execute("uci set firewall.ts_to_lan=forwarding")
    os.execute("uci set firewall.ts_to_lan.src='tailscale'")
    os.execute("uci set firewall.ts_to_lan.dest='lan'")
    
    -- Forwarding Rule: LAN -> Tailscale
    os.execute("uci set firewall.lan_to_ts=forwarding")
    os.execute("uci set firewall.lan_to_ts.src='lan'")
    os.execute("uci set firewall.lan_to_ts.dest='tailscale'")
    
    -- Cleanup old/custom names
    os.execute("uci delete network.ts_vwrt 2>/dev/null")
    os.execute("uci delete firewall.ts_vwrt 2>/dev/null")
    os.execute("uci delete firewall.vwrt_ts 2>/dev/null")
    
    os.execute("uci commit firewall")
    
    -- 4. Apply Changes
    os.execute("/etc/init.d/network reload")
    os.execute("/etc/init.d/firewall restart")
end

function main()
    local body = read_post_body()
    local request = {}
    if body then
        -- Robust logging for debug
        local f = io.open("/tmp/ts_debug_raw.log", "w")
        if f then f:write(body); f:close() end
        request = json.parse(body) or {}
    end
    
    local action = request.action
    local result = { status = "error", message = "Invalid action" }

    if action == "start" then
        os.execute("/etc/init.d/tailscale enable")
        os.execute("/etc/init.d/tailscale start")
        -- Apply config AFTER start because init script deletes it on stop/restart
        ensure_tailscale_config()
        result = { status = "success" }
        
    elseif action == "stop" then
        os.execute("/etc/init.d/tailscale stop")
        os.execute("/etc/init.d/tailscale disable")
        result = { status = "success" }
        
    elseif action == "logout" then
         -- Hard Reset: Full cleanup and state removal
         os.execute("/etc/init.d/tailscale stop")
         
         -- Remove Tailscale State (Hard Remove Account)
         os.execute("rm -f /etc/config/tailscaled.state")
         os.execute("rm -rf /etc/tailscale/*")
         
         -- Cleanup Network/Firewall
         os.execute("uci delete network.tailscale 2>/dev/null")
         os.execute("uci delete firewall.tailscale 2>/dev/null")
         os.execute("uci commit network")
         os.execute("uci commit firewall")
         os.execute("/etc/init.d/network reload")
         os.execute("/etc/init.d/firewall restart")
         
         -- Restart service to generate new fresh state
         os.execute("/etc/init.d/tailscale start")
         
         -- Recreate network/firewall definitions (they were just deleted)
         ensure_tailscale_config()
         
         result = { status = "success" }

    elseif action == "get_auth_url" then
        local raw = exec("tailscale status --json 2>/dev/null")
        local url = nil
        if raw and raw ~= "" then
             local ok, data = pcall(json.parse, raw)
             if ok and data.AuthURL then
                 url = data.AuthURL
             end
        end

        if not url then
            os.execute("echo '' > /tmp/tailscale_login.log")
            os.execute("(tailscale up --reset) > /tmp/tailscale_login.log 2>&1 &")
            os.execute("sleep 3")
            
            local f = io.open("/tmp/tailscale_login.log", "r")
            if f then
                local content = f:read("*all")
                f:close()
                url = content:match("(https://login%.tailscale%.com/a/[%w%d]+)")
            end
        end
        
        if url then
            result = { status = "success", url = url }
        else
            result = { status = "error", message = "Timeout fetching URL" }
        end
    elseif action == "check_auth_url" then
         local f = io.open("/tmp/tailscale_login.log", "r")
         local url = nil
         if f then
             local content = f:read("*all")
             f:close()
             url = content:match("(https://login%.tailscale%.com/a/[%w%d]+)")
         end
         if url then
             result = { status = "success", url = url }
         else
             result = { status = "pending" }
         end
    elseif action == "save_config" then
        local port = tonumber(request.port) or 41641
        local enabled = request.enabled and "1" or "0"
        
        os.execute("uci set tailscale.settings.port=" .. port)
        os.execute("uci set tailscale.settings.enabled=" .. enabled)
        os.execute("uci commit tailscale")
        
        -- Apply changes
        if enabled == "1" then
            os.execute("/etc/init.d/tailscale enable")
            os.execute("/etc/init.d/tailscale restart")
            -- CRITICAL: Apply config AFTER restart because init script deletes it on restart
            ensure_tailscale_config()
        else
            os.execute("/etc/init.d/tailscale stop")
            os.execute("/etc/init.d/tailscale disable")
            -- Cleanup on disable as requested
            os.execute("uci delete network.tailscale 2>/dev/null")
            os.execute("uci delete firewall.tailscale 2>/dev/null")
            os.execute("uci commit network")
            os.execute("uci commit firewall")
            os.execute("/etc/init.d/network reload")
            os.execute("/etc/init.d/firewall restart")
        end
        
        result = { status = "success" }
    end

    print("Content-type: application/json\n")
    print(json.stringify(result))
end

main()
