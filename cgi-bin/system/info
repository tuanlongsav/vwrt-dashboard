#!/usr/bin/lua

-- Add parent /www/vwrt/ to package path for lib modules
if not package.path:find("/www/vwrt") then
    package.path = "/www/vwrt/?.lua;" .. package.path
end

local cjson = require "cjson"
local constants = require "lib.constants"
local tmp_file_cpu = constants.PATHS.CPU_STAT
local cache_file = constants.PATHS.SYSTEM_CACHE
local cache_ttl = 1  -- Updated to 1s for faster refreshes 

-- ==========================================
-- CƠ CHẾ CACHE
-- ==========================================
function check_cache()
    local f = io.open(cache_file, "r")
    if not f then return nil end
    local content = f:read("*all")
    f:close()
    
    local handle = io.popen("date -r " .. cache_file .. " +%s 2>/dev/null")
    local file_time = tonumber(handle:read("*a")) or 0
    handle:close()

    local curr_time = os.time()
    
    if (curr_time - file_time) < cache_ttl and content and content ~= "" then
        return content
    end
    return nil
end

local cached_content = check_cache()
if cached_content then
    print("Content-type: application/json\n\n")
    print(cached_content)
    os.exit(0)
end

function read_file(path)
    local f = io.open(path, "r")
    if not f then return nil end
    local content = f:read("*all")
    f:close()
    return content
end

function write_file(path, content)
    local f = io.open(path, "w")
    if f then f:write(content) f:close() end
end

function get_mobile_temp()
    local f = io.open(constants.PATHS.MOBILE_CACHE, "r")
    if not f then return 0 end
    local content = f:read("*all")
    f:close()
    
    if content and content ~= "" then
        local ok, parsed = pcall(cjson.decode, content)
        if ok and parsed and parsed.mtemp then
             local s = tostring(parsed.mtemp)
             local n = s:match("([%d%.]+)")
             return tonumber(n) or 0
        end
    end
    return 0
end

-- ==========================================
-- TÊN THIẾT BỊ (MODEL)
-- ==========================================
function get_device_model()
    local model = read_file(constants.PATHS.SYSINFO_MODEL)
    if model and model ~= "" then
        return model:gsub("\n", "") 
    end
    
    local f = io.open("/proc/cpuinfo", "r")
    if f then
        for line in f:lines() do
            local m = line:match("Model%s+:%s+(.+)") or line:match("Machine%s+:%s+(.+)") or line:match("Hardware%s+:%s+(.+)")
            if m then
                f:close()
                return m
            end
        end
        f:close()
    end
    
    return "Unknown Device"
end

-- 3. CPU
function get_cpu_usage()
    local content = read_file("/proc/stat")
    if not content then return 0 end
    local line = content:match("cpu%s+(.+)")
    if not line then return 0 end
    local u, n, s, i, io, irq, sirq = line:match("(%d+)%s+(%d+)%s+(%d+)%s+(%d+)%s+(%d+)%s+(%d+)%s+(%d+)")
    if not u then return 0 end
    local current_total = u + n + s + i + io + irq + sirq
    local current_idle = i + io
    local last_data = read_file(tmp_file_cpu)
    local last_total, last_idle = 0, 0
    if last_data then
        last_total, last_idle = last_data:match("(%d+)%s+(%d+)")
        last_total = tonumber(last_total) or 0
        last_idle = tonumber(last_idle) or 0
    end
    write_file(tmp_file_cpu, string.format("%d %d", current_total, current_idle))
    if last_total == 0 then return 0 end
    local diff_total = current_total - last_total
    local diff_idle = current_idle - last_idle
    if diff_total <= 0 then return 0 end
    return math.floor(((diff_total - diff_idle) / diff_total) * 100)
end

-- 4. RAM
function get_memory()
    local content = read_file("/proc/meminfo") or ""
    local total = tonumber(content:match("MemTotal:%s*(%d+)")) or 1
    local available = tonumber(content:match("MemAvailable:%s*(%d+)"))
    if not available then
        local free = tonumber(content:match("MemFree:%s*(%d+)")) or 0
        local buffers = tonumber(content:match("Buffers:%s*(%d+)")) or 0
        local cached = tonumber(content:match("Cached:%s*(%d+)")) or 0
        available = free + buffers + cached
    end
    local used = total - available
    return { total = total * 1024, used = used * 1024, percent = math.floor((used / total) * 100) }
end

-- 5. ROM
function get_rom()
    local handle = io.popen("df /overlay | tail -n 1")
    local result = handle:read("*a")
    handle:close()
    local size, used, avail, pcent = result:match("%S+%s+(%d+)%s+(%d+)%s+(%d+)%s+(%d+)%%")
    if not size then 
         handle = io.popen("df / | tail -n 1")
         result = handle:read("*a")
         handle:close()
         size, used, avail, pcent = result:match("%S+%s+(%d+)%s+(%d+)%s+(%d+)%s+(%d+)%%")
    end
    return { total = (tonumber(size) or 0) * 1024, used = (tonumber(used) or 0) * 1024, percent = tonumber(pcent) or 0 }
end

-- 6. UPTIME & TEMP
function get_system_basic()
    local up_content = read_file("/proc/uptime") or "0"
    local uptime = tonumber(up_content:match("^(%d+)")) or 0
    
    local degree = 0
    
    local degree = 0
    
    -- Check system thermal zones dynamically
    local p = io.popen("ls /sys/class/thermal/thermal_zone*/temp 2>/dev/null")
    if p then
        for file in p:lines() do
            local content = read_file(file)
            if content then
                local val = tonumber(content) or 0
                if val > 1000 then val = val / 1000 end
                if val > 0 then
                    degree = val
                    break -- Found a valid temp, stop searching
                end
            end
        end
        p:close()
    end
    
    if degree == 0 then
        local mob_temp = get_mobile_temp()
        if mob_temp > 0 then
            degree = mob_temp
        end
    end
    
    -- Round to 1 decimal place
    degree = math.floor(degree * 10 + 0.5) / 10
    
    return { uptime = uptime, temp = degree }
end

-- ==========================================
-- LẤY TỔNG TRAFFIC (ĐỘNG 100% THEO UCI/UBUS)
-- ==========================================
function get_data_traffic()
    local total = 0
    local seen_devs = {}
    
    -- 1. Tìm Zone tên là 'wan' bằng vòng lặp an toàn
    local networks = ""
    for i = 0, 10 do -- Thử qua các index từ 0-10
        local p_name = io.popen(string.format("uci -q get firewall.@zone[%d].name", i))
        local name = p_name:read("*l")
        p_name:close()
        
        if not name then break end -- Hết zone
        if name == "wan" then
            local p_net = io.popen(string.format("uci -q get firewall.@zone[%d].network", i))
            networks = p_net:read("*a") or ""
            p_net:close()
            break
        end
    end
    
    -- 2. Duyệt qua từng network để lấy device thực tế
    for net in networks:gmatch("%S+") do
        local ubus_h = io.popen("ubus call network.interface." .. net .. " status 2>/dev/null")
        if ubus_h then
            local raw_json = ubus_h:read("*a")
            ubus_h:close()
            
            if raw_json and raw_json ~= "" then
                local ok, parsed = pcall(cjson.decode, raw_json)
                local dev = (ok and parsed) and (parsed.l3_device or parsed.device)
                
                -- 3. Chỉ cộng dồn nếu device tồn tại và chưa được tính (tránh tính trùng wan/wan6)
                if dev and not seen_devs[dev] and io.open("/sys/class/net/" .. dev) then
                    local rx = read_file("/sys/class/net/" .. dev .. "/statistics/rx_bytes")
                    local tx = read_file("/sys/class/net/" .. dev .. "/statistics/tx_bytes")
                    total = total + (tonumber(rx) or 0) + (tonumber(tx) or 0)
                    seen_devs[dev] = true
                end
            end
        end
    end
    
    return total
end

-- ==========================================
-- TỔNG HỢP VÀ GHI CACHE
-- ==========================================
local basic_info = get_system_basic()

local result = {
    model = get_device_model(),
    cpu = get_cpu_usage(),
    ram = get_memory(),
    rom = get_rom(),
    uptime = basic_info.uptime,
    temp = basic_info.temp,
    lan_total = get_data_traffic()  -- Trả lại traffic LAN (br-lan) theo yêu cầu
}

local json_output = cjson.encode(result)
write_file(cache_file, json_output)

print("Content-type: application/json\n\n")
print(json_output)