#!/usr/bin/lua

-- Dynamic Path Resolution
local source = debug.getinfo(1).source
local script_path = source:match("@?(.*[\\/])")
if script_path then
    local cgi_root = script_path:match("(.*cgi%-bin/)")
    if cgi_root then
        package.path = cgi_root .. "?.lua;" .. package.path
    end
end
if not package.path:find("/www/vwrt/cgi-bin") then
    package.path = "/www/vwrt/cgi-bin/?.lua;" .. package.path
end

local cjson = require "cjson"
local csrf = require "lib.csrf"

print("Content-type: application/json; charset=utf-8\n")

-- Helper to read body
local function get_input()
    local content_length = tonumber(os.getenv("CONTENT_LENGTH") or 0)
    if content_length > 0 then
        local raw = io.read(content_length)
        return cjson.decode(raw)
    end
    return nil
end

local function send_response(status, message)
    print(cjson.encode({ status = status, message = message }))
end

-- 1. Read Input
local input = get_input()
if not input or not input.action then
    send_response("error", "Invalid Request: Missing Action")
    os.exit()
end

-- 2. CSRF Check
local token = csrf.get_token_from_request() or input.csrf_token
if not csrf.validate_token(token) then
    send_response("error", "CSRF Token không hợp lệ!")
    os.exit()
end

-- 3. Process Action
local action = input.action
local param = input.param

if action == "reboot" then
    send_response("success", "Thiết bị đang khởi động lại...")
    os.execute("sleep 2 && reboot > /dev/null 2>&1 &")

elseif action == "reset" then
    send_response("success", "Đang khôi phục cài đặt gốc...")
    os.execute("sleep 2 && firstboot -y && reboot > /dev/null 2>&1 &")

elseif action == "restart_mobile" then
    send_response("success", "Đang khởi động lại dịch vụ Mobile...")
    
    -- 1. Universal Interface Restart
    os.execute("ifdown 5G; sleep 2; ifup 5G > /dev/null 2>&1 &")
    
    -- 2. Service Restart (Both ATC and ModemManager)
    os.execute("killall atc.sh > /dev/null 2>&1")
    os.execute("/etc/init.d/modemmanager restart > /dev/null 2>&1")
    os.execute("killall mobile_poller.lua > /dev/null 2>&1")
    
    local cmd = "lua /www/vwrt/services/mobile_poller.lua > /dev/null 2>&1 &"
    
    -- Wait 5s for services to get ready
    os.execute("sleep 5 && " .. cmd)

elseif action == "free_ram" then
    send_response("success", "Đã giải phóng bộ nhớ đệm (Drop Caches).")
    os.execute("sync && echo 3 > /proc/sys/vm/drop_caches")

else
    send_response("error", "Hành động không xác định")
end
